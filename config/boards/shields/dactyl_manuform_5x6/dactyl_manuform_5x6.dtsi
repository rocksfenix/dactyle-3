#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Dactyl Manuform 5x6";
        transform = <&default_transform>;
        kscan = <&kscan0>;
        keys =
            <&key_physical_attrs 100 100 0 0 0 0 0>,
            <&key_physical_attrs 100 100 100 0 0 0 0>,
            <&key_physical_attrs 100 100 200 0 0 0 0>,
            <&key_physical_attrs 100 100 300 0 0 0 0>,
            <&key_physical_attrs 100 100 400 0 0 0 0>,
            <&key_physical_attrs 100 100 500 0 0 0 0>,
            <&key_physical_attrs 100 100 600 0 0 0 0>,
            <&key_physical_attrs 100 100 700 0 0 0 0>,
            <&key_physical_attrs 100 100 800 0 0 0 0>,
            <&key_physical_attrs 100 100 900 0 0 0 0>,
            <&key_physical_attrs 100 100 1000 0 0 0 0>,
            <&key_physical_attrs 100 100 1100 0 0 0 0>,
            <&key_physical_attrs 100 100 1200 0 0 0 0>,
            <&key_physical_attrs 100 100 1300 0 0 0 0>,
            <&key_physical_attrs 100 100 1400 0 0 0 0>,
            <&key_physical_attrs 100 100 1500 0 0 0 0>,
            <&key_physical_attrs 100 100 1600 0 0 0 0>,
            <&key_physical_attrs 100 100 1700 0 0 0 0>,
            <&key_physical_attrs 100 100 1800 0 0 0 0>,
            <&key_physical_attrs 100 100 1900 0 0 0 0>,
            <&key_physical_attrs 100 100 2000 0 0 0 0>,
            <&key_physical_attrs 100 100 2100 0 0 0 0>,
            <&key_physical_attrs 100 100 2200 0 0 0 0>,
            <&key_physical_attrs 100 100 2300 0 0 0 0>,
            <&key_physical_attrs 100 100 2400 0 0 0 0>,
            <&key_physical_attrs 100 100 2500 0 0 0 0>,
            <&key_physical_attrs 100 100 2600 0 0 0 0>,
            <&key_physical_attrs 100 100 2700 0 0 0 0>,
            <&key_physical_attrs 100 100 2800 0 0 0 0>,
            <&key_physical_attrs 100 100 2900 0 0 0 0>,
            <&key_physical_attrs 100 100 3000 0 0 0 0>,
            <&key_physical_attrs 100 100 3100 0 0 0 0>,
            <&key_physical_attrs 100 100 3200 0 0 0 0>,
            <&key_physical_attrs 100 100 3300 0 0 0 0>,
            <&key_physical_attrs 100 100 3400 0 0 0 0>,
            <&key_physical_attrs 100 100 3500 0 0 0 0>,
            <&key_physical_attrs 100 100 3600 0 0 0 0>,
            <&key_physical_attrs 100 100 3700 0 0 0 0>,
            <&key_physical_attrs 100 100 3800 0 0 0 0>,
            <&key_physical_attrs 100 100 3900 0 0 0 0>,
            <&key_physical_attrs 100 100 4000 0 0 0 0>,
            <&key_physical_attrs 100 100 4100 0 0 0 0>,
            <&key_physical_attrs 100 100 4200 0 0 0 0>,
            <&key_physical_attrs 100 100 4300 0 0 0 0>,
            <&key_physical_attrs 100 100 4400 0 0 0 0>,
            <&key_physical_attrs 100 100 4500 0 0 0 0>,
            <&key_physical_attrs 100 100 4600 0 0 0 0>,
            <&key_physical_attrs 100 100 4700 0 0 0 0>,
            <&key_physical_attrs 100 100 4800 0 0 0 0>,
            <&key_physical_attrs 100 100 4900 0 0 0 0>,
            <&key_physical_attrs 100 100 5000 0 0 0 0>,
            <&key_physical_attrs 100 100 5100 0 0 0 0>,
            <&key_physical_attrs 100 100 5200 0 0 0 0>,
            <&key_physical_attrs 100 100 5300 0 0 0 0>,
            <&key_physical_attrs 100 100 5400 0 0 0 0>,
            <&key_physical_attrs 100 100 5500 0 0 0 0>,
            <&key_physical_attrs 100 100 5600 0 0 0 0>,
            <&key_physical_attrs 100 100 5700 0 0 0 0>,
            <&key_physical_attrs 100 100 5800 0 0 0 0>,
            <&key_physical_attrs 100 100 5900 0 0 0 0>,
            <&key_physical_attrs 100 100 6000 0 0 0 0>,
            <&key_physical_attrs 100 100 6100 0 0 0 0>,
            <&key_physical_attrs 100 100 6200 0 0 0 0>,
            <&key_physical_attrs 100 100 6300 0 0 0 0>,
            <&key_physical_attrs 100 100 6400 0 0 0 0>,
            <&key_physical_attrs 100 100 6500 0 0 0 0>,
            <&key_physical_attrs 100 100 6600 0 0 0 0>,
            <&key_physical_attrs 100 100 6700 0 0 0 0>,
            <&key_physical_attrs 100 100 6800 0 0 0 0>,
            <&key_physical_attrs 100 100 6900 0 0 0 0>,
            <&key_physical_attrs 100 100 7000 0 0 0 0>,
            <&key_physical_attrs 100 100 7100 0 0 0 0>,
            <&key_physical_attrs 100 100 7200 0 0 0 0>,
            <&key_physical_attrs 100 100 7300 0 0 0 0>,
            <&key_physical_attrs 100 100 7400 0 0 0 0>,
            <&key_physical_attrs 100 100 7500 0 0 0 0>,
            <&key_physical_attrs 100 100 7600 0 0 0 0>,
            <&key_physical_attrs 100 100 7700 0 0 0 0>,
            <&key_physical_attrs 100 100 7800 0 0 0 0>,
            <&key_physical_attrs 100 100 7900 0 0 0 0>,
            <&key_physical_attrs 100 100 8000 0 0 0 0>,
            <&key_physical_attrs 100 100 8100 0 0 0 0>,
            <&key_physical_attrs 100 100 8200 0 0 0 0>,
            <&key_physical_attrs 100 100 8300 0 0 0 0>,
            <&key_physical_attrs 100 100 8400 0 0 0 0>,
            <&key_physical_attrs 100 100 8500 0 0 0 0>;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <7>;
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6)          RC(0,13) RC(0,12) RC(0,11) RC(0,10) RC(0,9) RC(0,8) RC(0,7)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6)          RC(1,13) RC(1,12) RC(1,11) RC(1,10) RC(1,9) RC(1,8) RC(1,7)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6)          RC(2,13) RC(2,12) RC(2,11) RC(2,10) RC(2,9) RC(2,8) RC(2,7)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6)          RC(3,13) RC(3,12) RC(3,11) RC(3,10) RC(3,9) RC(3,8) RC(3,7)
RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5) RC(4,6)          RC(4,13) RC(4,12) RC(4,11) RC(4,10) RC(4,9) RC(4,8) RC(4,7)
                RC(5,2) RC(5,3)                                                             RC(5,10) RC(5,9)
                                RC(5,4) RC(5,5)                  RC(5,12) RC(5,11)
                                RC(6,4) RC(5,6)                  RC(5,13) RC(6,11)
                                RC(6,5) RC(6,6)                  RC(6,13) RC(6,12)
                                                                    
                                                                    
                                                                 
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";

        diode-direction = "col2row";
        row-gpios
            = <&gpio0 29 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;

    };
};
