#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Dactyl Manuform 5x6";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        keys =
        // Row 0 (14)
        <&key_physical_attrs 100 100    0    0 0 0 0>,
        <&key_physical_attrs 100 100  110    0 0 0 0>,
        <&key_physical_attrs 100 100  220    0 0 0 0>,
        <&key_physical_attrs 100 100  330    0 0 0 0>,
        <&key_physical_attrs 100 100  440    0 0 0 0>,
        <&key_physical_attrs 100 100  550    0 0 0 0>,
        <&key_physical_attrs 100 100  660    0 0 0 0>,
        <&key_physical_attrs 100 100 1020    0 0 0 0>,
        <&key_physical_attrs 100 100 1130    0 0 0 0>,
        <&key_physical_attrs 100 100 1240    0 0 0 0>,
        <&key_physical_attrs 100 100 1350    0 0 0 0>,
        <&key_physical_attrs 100 100 1460    0 0 0 0>,
        <&key_physical_attrs 100 100 1570    0 0 0 0>,
        <&key_physical_attrs 100 100 1680    0 0 0 0>,
        // Row 1 (14)
        <&key_physical_attrs 100 100    0  110 0 0 0>,
        <&key_physical_attrs 100 100  110  110 0 0 0>,
        <&key_physical_attrs 100 100  220  110 0 0 0>,
        <&key_physical_attrs 100 100  330  110 0 0 0>,
        <&key_physical_attrs 100 100  440  110 0 0 0>,
        <&key_physical_attrs 100 100  550  110 0 0 0>,
        <&key_physical_attrs 100 100  660  110 0 0 0>,
        <&key_physical_attrs 100 100 1020  110 0 0 0>,
        <&key_physical_attrs 100 100 1130  110 0 0 0>,
        <&key_physical_attrs 100 100 1240  110 0 0 0>,
        <&key_physical_attrs 100 100 1350  110 0 0 0>,
        <&key_physical_attrs 100 100 1460  110 0 0 0>,
        <&key_physical_attrs 100 100 1570  110 0 0 0>,
        <&key_physical_attrs 100 100 1680  110 0 0 0>,
        // Row 2 (14)
        <&key_physical_attrs 100 100    0  220 0 0 0>,
        <&key_physical_attrs 100 100  110  220 0 0 0>,
        <&key_physical_attrs 100 100  220  220 0 0 0>,
        <&key_physical_attrs 100 100  330  220 0 0 0>,
        <&key_physical_attrs 100 100  440  220 0 0 0>,
        <&key_physical_attrs 100 100  550  220 0 0 0>,
        <&key_physical_attrs 100 100  660  220 0 0 0>,
        <&key_physical_attrs 100 100 1020  220 0 0 0>,
        <&key_physical_attrs 100 100 1130  220 0 0 0>,
        <&key_physical_attrs 100 100 1240  220 0 0 0>,
        <&key_physical_attrs 100 100 1350  220 0 0 0>,
        <&key_physical_attrs 100 100 1460  220 0 0 0>,
        <&key_physical_attrs 100 100 1570  220 0 0 0>,
        <&key_physical_attrs 100 100 1680  220 0 0 0>,
        // Row 3 (14)
        <&key_physical_attrs 100 100    0  330 0 0 0>,
        <&key_physical_attrs 100 100  110  330 0 0 0>,
        <&key_physical_attrs 100 100  220  330 0 0 0>,
        <&key_physical_attrs 100 100  330  330 0 0 0>,
        <&key_physical_attrs 100 100  440  330 0 0 0>,
        <&key_physical_attrs 100 100  550  330 0 0 0>,
        <&key_physical_attrs 100 100  660  330 0 0 0>,
        <&key_physical_attrs 100 100 1020  330 0 0 0>,
        <&key_physical_attrs 100 100 1130  330 0 0 0>,
        <&key_physical_attrs 100 100 1240  330 0 0 0>,
        <&key_physical_attrs 100 100 1350  330 0 0 0>,
        <&key_physical_attrs 100 100 1460  330 0 0 0>,
        <&key_physical_attrs 100 100 1570  330 0 0 0>,
        <&key_physical_attrs 100 100 1680  330 0 0 0>,
        // Row 4 (14)
        <&key_physical_attrs 100 100    0  440 0 0 0>,
        <&key_physical_attrs 100 100  110  440 0 0 0>,
        <&key_physical_attrs 100 100  220  440 0 0 0>,
        <&key_physical_attrs 100 100  330  440 0 0 0>,
        <&key_physical_attrs 100 100  440  440 0 0 0>,
        <&key_physical_attrs 100 100  550  440 0 0 0>,
        <&key_physical_attrs 100 100  660  440 0 0 0>,
        <&key_physical_attrs 100 100 1020  440 0 0 0>,
        <&key_physical_attrs 100 100 1130  440 0 0 0>,
        <&key_physical_attrs 100 100 1240  440 0 0 0>,
        <&key_physical_attrs 100 100 1350  440 0 0 0>,
        <&key_physical_attrs 100 100 1460  440 0 0 0>,
        <&key_physical_attrs 100 100 1570  440 0 0 0>,
        <&key_physical_attrs 100 100 1680  440 0 0 0>,
        // Mid pair row (4)
        <&key_physical_attrs 100 100  330  570 0 0 0>,
        <&key_physical_attrs 100 100  440  570 0 0 0>,
        <&key_physical_attrs 100 100 1240  570 0 0 0>,
        <&key_physical_attrs 100 100 1350  570 0 0 0>,
        // Thumb row 1 (4) - rotated
        <&key_physical_attrs 100 100  520  700 (-800)  620 760>,
        <&key_physical_attrs 100 100  640  690 (-1400) 730 750>,
        <&key_physical_attrs 100 100 1040  690  (1400) 950 750>,
        <&key_physical_attrs 100 100 1160  700   (800) 1060 760>,
        // Thumb row 2 (4) - rotated
        <&key_physical_attrs 100 100  500  820 (-1200) 600 870>,
        <&key_physical_attrs 100 100  630  810 (-1800) 720 860>,
        <&key_physical_attrs 100 100 1050  810  (1800) 960 860>,
        <&key_physical_attrs 100 100 1180  820  (1200) 1080 870>,
        // Thumb row 3 (4) - rotated
        <&key_physical_attrs 100 100  490  940 (-1600) 590 980>,
        <&key_physical_attrs 100 100  620  930 (-2200) 710 970>,
        <&key_physical_attrs 100 100 1060  930  (2200) 970 970>,
        <&key_physical_attrs 100 100 1190  940  (1600) 1090 980>;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <7>;
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6)          RC(0,13) RC(0,12) RC(0,11) RC(0,10) RC(0,9) RC(0,8) RC(0,7)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6)          RC(1,13) RC(1,12) RC(1,11) RC(1,10) RC(1,9) RC(1,8) RC(1,7)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6)          RC(2,13) RC(2,12) RC(2,11) RC(2,10) RC(2,9) RC(2,8) RC(2,7)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6)          RC(3,13) RC(3,12) RC(3,11) RC(3,10) RC(3,9) RC(3,8) RC(3,7)
RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5) RC(4,6)          RC(4,13) RC(4,12) RC(4,11) RC(4,10) RC(4,9) RC(4,8) RC(4,7)
                RC(5,2) RC(5,3)                                                             RC(5,10) RC(5,9)
                                RC(5,4) RC(5,5)                  RC(5,12) RC(5,11)
                                RC(6,4) RC(5,6)                  RC(5,13) RC(6,11)
                                RC(6,5) RC(6,6)                  RC(6,13) RC(6,12)
                                                                    
                                                                    
                                                                 
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";

        diode-direction = "col2row";
        row-gpios
            = <&gpio0 29 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio1 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;

    };
};
